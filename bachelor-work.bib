  author = {Liu, Ji and Huang, Jizhou and Zhou, Yang and Li, Xuhong and Ji, Shilei and Xiong, Haoyi and Dou, Dejing},
  date = {2022-04},
  journaltitle = {Knowledge and Information Systems},
  shortjournal = {Knowl Inf Syst},
  volume = {64},
  number = {4},
  eprint = {2104.14362},
  eprinttype = {arXiv},
